{
  "name": "immich-journal",
  "version": "0.2.0-beta.1",
  "description": "Obsidian plugin: insert photos from a self-hosted Immich server into daily notes",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run tsc && node esbuild.config.mjs production",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "esbuild": "0.13.12",
    "eslint": "^10.6.0",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^0.34.0"
  }
}
