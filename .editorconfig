# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8

# TypeScript and JavaScript files use tabs (per obsidian-sample-plugin convention)
[*.{ts,tsx,js,jsx,mjs}]
indent_style = tab

# JSON, YAML, and Markdown use 2 spaces
[*.{json,yaml,yml,md}]
indent_style = space
indent_size = 2
